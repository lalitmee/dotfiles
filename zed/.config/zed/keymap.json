// Zed keymap - Neovim parity
// See https://zed.dev/docs/key-bindings
[
  // INSERT mode
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "k j": "vim::NormalBefore",
    },
  },

  // NORMAL mode
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      // files
      "space f f": "file_finder::Toggle",
      "space f s": "workspace::Save",
      "space f w": "workspace::SaveWithoutFormat",

      // panels
      "space a e": "workspace::ToggleLeftDock",

      // git
      "space g s": "workspace::ToggleRightDock",

      // search
      "space /": "pane::DeploySearch",

      // windows
      "space w s": "pane::SplitDown",
      "space w v": "pane::SplitRight",
      "space w d": ["pane::CloseActiveItem", { "close_pinned": false }],

      // terminal
      "space t t": "terminal_panel::Toggle",
      "space t c": "workspace::NewCenterTerminal",

      // buffers
      "space b b": "tab_switcher::Toggle",
      "space b l": "buffer_search::Deploy",
      "space b s": "outline::Toggle",
      "space b d": ["pane::CloseActiveItem", { "close_pinned": false }],

      // folds
      "enter": "editor::ToggleFold",

      // misc
      "shift-y": ["workspace::SendKeystrokes", "y $"],
    },
  },

  // VISUAL mode
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      "J": "editor::MoveLineDown",
      "K": "editor::MoveLineUp",
    },
  },

  {
    "context": "VimControl && !menu",
    "bindings": {
      "H": ["workspace::SendKeystrokes", "0"],
      "L": ["workspace::SendKeystrokes", "$"],
    },
  },
]
