// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
//
// NOTE: Zed doesn't yet support ${env:VAR} interpolation in settings.json
// Track progress: https://github.com/zed-industries/zed/discussions/26043
// When available, use syntax like: "api_key": "${env:MY_API_KEY}"
{
  "edit_predictions": {
    "provider": "copilot"
  },
  "languages": {
    "INI": {
      "editor": {
        "folding": {
          "strategy": "marker",
        },
      },
    },
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "enabled",
  "file_types": {
    "ini": ["env", ".env", ".env.*"],
  },
  "agent": {
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-pro",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "project_panel": {
    "button": true,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": true,
  },
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_icon": true,
  },
  "ui_font_family": ".ZedMono",
  "ui_font_weight": 300.0,
  "terminal": {
    "font_weight": 300.0,
  },
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 14.0,
  "agent_servers": {
    "opencode": {
      "type": "custom",
      "command": "opencode",
      "args": [],
      "env": {},
    },
  },
  // NOTE: If you need to add MCP servers or context servers with API keys in the future,
  // manually edit ~/.config/zed/settings.json after stowing this config.
  // Do NOT commit API keys to version control.
  "context_servers": {},
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 14.0,
  "buffer_font_family": "Operator Mono Lig",
  "buffer_font_size": 14,
  "buffer_font_weight": 300,
  "theme": "Catppuccin Mocha",
}
