// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
//
// NOTE: Zed doesn't yet support ${env:VAR} interpolation in settings.json
// Track progress: https://github.com/zed-industries/zed/discussions/26043
// When available, use syntax like: "api_key": "${env:MY_API_KEY}"
{
  "soft_wrap": "bounded",
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "ui_font_family": ".ZedMono",
  "buffer_font_size": 12.0,
  "buffer_font_family": "Operator Mono Lig",
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
  },
  "languages": {
    "ini": {},
    "C": {
      "tab_size": 4,
      "hard_tabs": true,
    },
    "C++": {
      "tab_size": 4,
      "hard_tabs": true,
    },
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "on",
    },
    "Python": {
      "tab_size": 4,
      "hard_tabs": false,
    },
    "Rust": {
      "tab_size": 4,
      "hard_tabs": false,
      "format_on_save": "on",
    },
    "Lua": {
      "tab_size": 2,
      "hard_tabs": false,
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": [],
        },
      },
    },
    "Zig": {
      "tab_size": 4,
      "hard_tabs": false,
    },
    "YAML": {
      "tab_size": 2,
      "hard_tabs": false,
    },
    "JSON": {
      "tab_size": 2,
      "hard_tabs": false,
    },
    "JavaScript": {
      "tab_size": 2,
      "hard_tabs": false,
    },
    "TypeScript": {
      "tab_size": 2,
      "hard_tabs": false,
    },
    "CSS": {
      "tab_size": 2,
      "hard_tabs": false,
    },
    "HTML": {
      "tab_size": 2,
      "hard_tabs": false,
    },
    "Markdown": {
      "tab_size": 2,
      "hard_tabs": false,
      "soft_wrap": "editor_width",
    },
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "enabled",
  "file_types": {
    "INI": ["env", ".env", ".env.*"],
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "effort": "minimal",
      "enable_thinking": true,
      "provider": "google",
      "model": "gemini-3.5-flash",
    },
    "model_parameters": [],
  },
  "project_panel": {
    "dock": "left",
    "button": true,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": true,
  },
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false,
  },
  "ui_font_weight": 300.0,
  "terminal": {
    "font_weight": 300.0,
  },
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 14.0,
  "agent_servers": {
    "gemini-custom": {
      "type": "custom",
      "command": "gemini",
    },
    "opencode": {
      "type": "custom",
      "command": "opencode",
      "args": [],
      "env": {},
    },
  },
  // NOTE: If you need to add MCP servers or context servers with API keys in the future,
  // manually edit ~/.config/zed/settings.json after stowing this config.
  // Do NOT commit API keys to version control.
  "context_servers": {
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "remote": false,
      "settings": {
        "browser_url": null,
        "ws_endpoint": null,
        "ws_headers": null,
        "auto_connect": null,
        "channel": null,
        "headless": null,
        "isolated": null,
        "user_data_dir": null,
        "viewport": null,
        "executable_path": null,
        "chrome_arg": [],
        "proxy_server": null,
        "accept_insecure_certs": null,
        "category_emulation": null,
        "category_performance": null,
        "category_network": null,
        "log_file": null,
        "extra_args": [],
      },
    },
  },
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 14.0,
  "buffer_font_weight": 300.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "lsp": {
    "clangd": {
      "binary": {
        "path": "clangd",
        "arguments": [
          "--background-index",
          "--suggest-missing-includes",
          "--clang-tidy",
          "--header-insertion=iwyu",
        ],
      },
    },
    "gopls": {
      "settings": {
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "lua-language-server": {
      "settings": {
        "Lua": {
          "hint": { "enable": true },
          "format": { "enable": false },
          "diagnostics": {
            "globals": [
              "P",
              "R",
              "RELOAD",
              "Snacks",
              "__lk_global_callbacks",
              "after_each",
              "before_each",
              "describe",
              "it",
              "lk",
              "require",
              "vim",
              "_dd",
              "_bt",
            ],
          },
          "completion": {
            "keywordSnippet": "Replace",
            "callSnippet": "Replace",
          },
          "workspace": {
            "checkThirdParty": false,
          },
          "telemetry": {
            "enable": false,
          },
        },
      },
    },
    "rust-analyzer": {
      "settings": {
        "rust-analyzer": {
          "inlayHints": { "locationLinks": true },
          "diagnostics": { "enable": true },
          "hover": { "actions": { "enable": true } },
          "procMacro": { "enable": true },
          "cargo": { "allFeatures": true },
          "checkOnSave": {
            "command": "clippy",
            "extraArgs": ["--no-deps"],
          },
        },
      },
    },
  },
}
